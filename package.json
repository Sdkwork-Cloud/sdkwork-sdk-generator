{
  "name": "@sdkwork/sdk-generator",
  "version": "1.0.5",
  "description": "SDKWork SDK Generator - Professional SDK code generator for TypeScript, Dart, Python, Go, Java, Kotlin, Swift, C#, Flutter, Rust, PHP, and Ruby",
  "author": "SDKWork Team",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "sdkgen": "bin/sdkgen.js"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./node/output-sync": {
      "import": "./tmp-js/node/output-sync.js",
      "types": "./dist/node/output-sync.d.ts"
    },
    "./node/generate": {
      "import": "./tmp-js/node/generate.js",
      "types": "./dist/node/generate.d.ts"
    },
    "./node/execution-report": {
      "import": "./tmp-js/node/execution-report.js",
      "types": "./dist/node/execution-report.d.ts"
    },
    "./node/control-plane": {
      "import": "./tmp-js/node/control-plane.js",
      "types": "./dist/node/control-plane.d.ts"
    },
    "./node/init": {
      "import": "./tmp-js/node/init.js",
      "types": "./dist/node/init.d.ts"
    }
  },
  "files": [
    "dist",
    "tmp-js",
    "bin",
    "templates",
    "README.md"
  ],
  "scripts": {
    "dev": "vite build --watch",
    "build": "npm run clean && tsc --emitDeclarationOnly && npm run build:bundle && tsc -p tsconfig.runtime.json",
    "build:bundle": "esbuild src/index.ts --bundle --platform=node --target=es2020 --format=esm --outfile=dist/index.js --sourcemap --external:@sdkwork/sdk-common --external:@sdkwork/sdk-common/* && esbuild src/index.ts --bundle --platform=node --target=es2020 --format=cjs --outfile=dist/index.cjs --sourcemap --external:@sdkwork/sdk-common --external:@sdkwork/sdk-common/*",
    "lint": "tsc --noEmit && tsc --noEmit -p tsconfig.runtime.json",
    "test": "node ./bin/test-runner.mjs",
    "test:vitest": "vitest",
    "clean": "node ./bin/clean.mjs",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "sdkwork",
    "sdk",
    "generator",
    "code-generator",
    "typescript",
    "dart",
    "flutter",
    "swift",
    "java",
    "csharp",
    "rust",
    "php",
    "ruby"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sdkwork/spring-ai-plus.git",
    "directory": "spring-ai-plus-business/sdk/sdkwork-sdk-generator"
  },
  "bugs": {
    "url": "https://github.com/sdkwork/spring-ai-plus/issues"
  },
  "homepage": "https://github.com/sdkwork/spring-ai-plus#readme",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@sdkwork/sdk-common": "1.0.2",
    "commander": "^12.0.0",
    "fs-extra": "^11.2.0",
    "handlebars": "^4.7.8",
    "js-yaml": "^4.1.0",
    "lodash": "^4.17.21",
    "openapi-types": "^12.1.3",
    "prettier": "^3.2.5",
    "swagger-parser": "^10.0.3"
  },
  "devDependencies": {
    "@types/fs-extra": "^11.0.4",
    "@types/js-yaml": "^4.0.9",
    "@types/lodash": "^4.14.202",
    "@types/node": "^20.10.0",
    "typescript": "^5.3.2",
    "vite": "^7.3.1",
    "vite-plugin-dts": "^4.5.4",
    "vitest": "^1.0.4"
  }
}
