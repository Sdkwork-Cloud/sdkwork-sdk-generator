{
  "name": "@sdkwork/sdk-generator",
  "version": "1.0.2",
  "description": "SDKWork SDK Generator - Professional SDK code generator for multiple languages",
  "author": "SDKWork Team",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "sdkgen": "./bin/sdkgen.js"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "tmp-js",
    "bin",
    "templates",
    "README.md"
  ],
  "scripts": {
    "dev": "vite build --watch",
    "build": "tsc --emitDeclarationOnly && vite build && tsc -p tsconfig.runtime.json",
    "lint": "eslint src --ext .ts",
    "test": "vitest",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "sdkwork",
    "sdk",
    "generator",
    "code-generator",
    "typescript",
    "flutter",
    "swift",
    "java",
    "csharp",
    "rust"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/sdkwork/spring-ai-plus.git",
    "directory": "spring-ai-plus-business/sdk/sdkwork-sdk-generator"
  },
  "bugs": {
    "url": "https://github.com/sdkwork/spring-ai-plus/issues"
  },
  "homepage": "https://github.com/sdkwork/spring-ai-plus#readme",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@sdkwork/sdk-common": "1.0.2",
    "commander": "^12.0.0",
    "fs-extra": "^11.2.0",
    "handlebars": "^4.7.8",
    "js-yaml": "^4.1.0",
    "lodash": "^4.17.21",
    "openapi-types": "^12.1.3",
    "prettier": "^3.2.5",
    "swagger-parser": "^10.0.3"
  },
  "devDependencies": {
    "@types/fs-extra": "^11.0.4",
    "@types/js-yaml": "^4.0.9",
    "@types/lodash": "^4.14.202",
    "@types/node": "^20.10.0",
    "typescript": "^5.3.2",
    "vite": "^7.3.1",
    "vite-plugin-dts": "^4.5.4",
    "vitest": "^1.0.4"
  }
}
